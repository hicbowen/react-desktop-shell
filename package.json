{
  "name": "react-desktop-shell",
  "version": "0.7.2",
  "type": "module",
  "description": "A lightweight native-like desktop app shell for building React desktop applications.",
  "license": "MIT",
  "author": "hicbowen",
  "keywords": [
    "react",
    "desktop",
    "app-shell",
    "titlebar",
    "navigation",
    "sidebar",
    "wails",
    "electron",
    "tauri",
    "fluent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hicbowen/react-desktop-shell.git"
  },
  "homepage": "https://github.com/hicbowen/react-desktop-shell#readme",
  "bugs": {
    "url": "https://github.com/hicbowen/react-desktop-shell/issues"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./antd": {
      "types": "./dist/antd/index.d.ts",
      "import": "./dist/antd/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js"
    },
    "./style.css": "./dist/style.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "dev": "vite --config vite.example.config.ts",
    "build": "npm run clean && vite build && tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "test": "vitest run",
    "prepack": "npm run lint && npm run build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "@tanstack/react-table": ">=8.21.0 <9.0.0",
    "antd": ">=5.0.0 <7.0.0",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-table": {
      "optional": true
    },
    "antd": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "antd": "^6.5.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8.0.14",
    "vitest": "^4.1.10"
  }
}
